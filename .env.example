# ═══════════════════════════════════════════
#  NationRP — Configuration
#  Copie ce fichier en .env et remplis les valeurs
# ═══════════════════════════════════════════

# ─── DISCORD ─────────────────────────────────
# Crée ton bot sur https://discord.com/developers/applications
# Active les intents : Message Content, Server Members, Guilds
DISCORD_TOKEN=ton_token_discord_ici
GUILD_ID=123456789012345678

# ─── IA — CHOISIS TON PROVIDER ───────────────
# "gemini" (recommandé) ou "groq"
AI_PROVIDER=gemini

# Google Gemini 1.5 Pro — GRATUIT
# 1 000 000 tokens de contexte | 1 500 req/jour | 0 €
# Clé API : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=ta_cle_gemini_ici

# Groq — GRATUIT (alternative ultra rapide)
# Llama 3.3 70B | ~130 000 tokens contexte | 14 400 req/jour
# Clé API : https://console.groq.com
GROQ_API_KEY=ta_cle_groq_ici

# ─── BACKEND ─────────────────────────────────
BACKEND_URL=http://localhost:8000

# ─── CAPTURE ─────────────────────────────────
# Intervalle de capture en secondes (défaut : 5 minutes)
CAPTURE_INTERVAL=300
# Nombre de messages à récupérer par salon
HISTORY_LIMIT=500
